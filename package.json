{
  "name": "obsidian-ticktick-simple-sync",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bunx esbuild src/main.ts --bundle --format=cjs --platform=browser --target=es2020 --external:obsidian --outfile=main.js",
    "dev": "bunx esbuild src/main.ts --bundle --format=cjs --platform=browser --target=es2020 --external:obsidian --outfile=main.js --watch",
    "check": "bunx tsc --noEmit",
    "lint": "bunx eslint src/main.ts"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@typescript-eslint/parser": "^8.56.0",
    "esbuild": "^0.25.9",
    "eslint": "^10.0.1",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "^1.8.7",
    "typescript": "^5.9.2"
  }
}
